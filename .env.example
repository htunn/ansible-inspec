# ansible-inspec Environment Configuration

# General Settings
DEBUG=false
DATA_DIR=./data
LOG_LEVEL=INFO

# Storage Backend: file (no database), database (PostgreSQL), or hybrid (migration)
STORAGE_BACKEND=file
VALIDATION_DAYS=30
AUTO_CUTOVER=false

# Server Settings
HOST=0.0.0.0
PORT=8080
RELOAD=false

# CORS Settings (comma-separated)
CORS_ORIGINS=http://localhost:8081,http://localhost:3000

# Encryption
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# REQUIRED: Generate your own key for production
ENCRYPTION_KEY=

# Authentication
AUTH__ENABLED=false
AUTH__AZURE_TENANT_ID=
AUTH__AZURE_CLIENT_ID=
AUTH__AZURE_CLIENT_SECRET=
# REQUIRED: Generate your own secret for production
# python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH__JWT_SECRET=
AUTH__JWT_ALGORITHM=HS256
AUTH__ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH__REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH__OAUTH_REDIRECT_URI=http://localhost:8080/api/v1/auth/callback

# Database (Prisma ORM)
# OPTIONAL: Only required if STORAGE_BACKEND=database or STORAGE_BACKEND=hybrid
# Leave empty/commented for file storage (default)
# Note: Prisma uses standard PostgreSQL URLs (no +asyncpg or +aiosqlite)
# For local development:
# DATABASE__URL=postgresql://ansibleinspec:YOUR_PASSWORD@localhost:5432/ansibleinspec
# DATABASE_URL=postgresql://ansibleinspec:YOUR_PASSWORD@localhost:5432/ansibleinspec
# For Docker Compose:
# DATABASE__URL=postgresql://ansibleinspec:YOUR_PASSWORD@postgres:5432/ansibleinspec
# DATABASE_URL=postgresql://ansibleinspec:YOUR_PASSWORD@postgres:5432/ansibleinspec

# Docker Compose Database Settings (optional - only for database storage)
# POSTGRES_USER=ansibleinspec
# POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
# POSTGRES_DB=ansibleinspec
# POSTGRES_PORT=5432

# API Server
API_PORT=8080

# VCS Integration
VCS__ENABLED=false
VCS__POLL_INTERVAL_MINUTES=15
VCS__CONFIG_DIR=./data/vcs_repos
VCS__WEBHOOK_ENABLED=false
VCS__WEBHOOK_SECRET=

# Monitoring
MONITORING__PROMETHEUS_ENABLED=true
MONITORING__ALERT_EMAIL=
MONITORING__ALERT_WEBHOOK=
